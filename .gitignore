# Secrets & credentials
.env
.env.*
!.env.template
*service_account*.json
credentials.json

# Interest expense (personal data from Form 1098)
interest_expense.yaml

# Tax data — never commit personal/client financial documents
years/*/inputs/
years/*/outputs/
years/*/intermediate/
years/*/review_log.csv

# Logs & local Claude settings
logs/
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# IDE
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Exception: allow anonymized test fixtures
!tests/fixtures/**
# But never allow raw discovery dumps
tests/fixtures/**/_txt_*/
tests/fixtures/**/_raw_*
tests/fixtures/**/raw/
tests/fixtures/**/dump/
tests/fixtures/**/*.raw.txt
# And never allow secrets under fixtures
tests/fixtures/**/.env
tests/fixtures/**/.env.*
tests/fixtures/**/*service_account*.json
tests/fixtures/**/credentials.json
CLAUDE.md
